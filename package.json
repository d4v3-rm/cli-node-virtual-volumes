{
  "name": "virtual-volumes-cli",
  "version": "0.2.0",
  "description": "Node.js virtual volumes with a custom filesystem and a rich terminal UI.",
  "type": "module",
  "bin": {
    "virtual-volumes": "./dist/index.js"
  },
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    },
    "./cli": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm run test",
    "prepack": "npm run build"
  },
  "keywords": [
    "cli",
    "filesystem",
    "nodejs",
    "terminal-ui",
    "typescript",
    "virtual-volume"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/blessed": "^0.1.27",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "nanoid": "^5.1.7",
    "neo-blessed": "^0.2.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  }
}
